<?xml version="1.0" encoding="UTF-8" ?>
<lint
    checkTestSources="true"
    checkDependencies="false" >

    <!--
        历史遗留翻译债务：项目支持 4 个非默认语言（de/ja/ko/zh），但大量英文
        字符串尚未翻译，且各语言文件存在只在默认或只在翻译中的条目。手工对齐
        250+ 条翻译成本高、易出错，因此忽略 MissingTranslation / ExtraTranslation，
        后续可按语言分批补齐翻译。
    -->
    <issue id="MissingTranslation" severity="ignore" />
    <issue id="ExtraTranslation" severity="ignore" />

    <!--
        以下多为风格、质量或项目当前不优先处理的警告。由于历史代码量大，逐一
        修复收益不高，先忽略以保持 lint 报告干净，后续重构时逐步解决。
    -->
    <issue id="UseKtx" severity="ignore" />
    <issue id="UnusedResources" severity="ignore" />
    <issue id="HardcodedText" severity="ignore" />
    <issue id="SetTextI18n" severity="ignore" />
    <issue id="ButtonStyle" severity="ignore" />
    <issue id="UseCompatLoadingForDrawables" severity="ignore" />
    <issue id="NotifyDataSetChanged" severity="ignore" />
    <issue id="TypographyEllipsis" severity="ignore" />
    <issue id="LabelFor" severity="ignore" />
    <issue id="PluralsCandidate" severity="ignore" />
    <issue id="Autofill" severity="ignore" />
    <issue id="UnusedAttribute" severity="ignore" />
    <issue id="Typos" severity="ignore" />
    <issue id="TypographyDashes" severity="ignore" />
    <issue id="ObsoleteSdkInt" severity="ignore" />
    <issue id="UseCompoundDrawables" severity="ignore" />
    <issue id="DisableBaselineAlignment" severity="ignore" />
    <issue id="ContentDescription" severity="ignore" />
    <issue id="ClickableViewAccessibility" severity="ignore" />
    <issue id="UseSwitchCompatOrMaterialXml" severity="ignore" />
    <issue id="SmallSp" severity="ignore" />
    <issue id="DiscouragedApi" severity="ignore" />
    <issue id="CheckResult" severity="ignore" />
    <issue id="UselessParent" severity="ignore" />
    <issue id="TooManyViews" severity="ignore" />
    <issue id="TooDeepLayout" severity="ignore" />
    <issue id="RtlSymmetry" severity="ignore" />
    <issue id="Overdraw" severity="ignore" />

    <!-- 依赖库原生库或系统限制，项目层面无法直接修复 -->
    <issue id="Aligned16KB" severity="ignore" />
    <issue id="LockedOrientationActivity" severity="ignore" />
    <issue id="AppBundleLocaleChanges" severity="ignore" />
    <issue id="QueryPermissionsNeeded" severity="ignore" />
    <issue id="SelectedPhotoAccess" severity="ignore" />
    <issue id="MonochromeLauncherIcon" severity="ignore" />

    <!-- TrustAllX509TrustManager 在 Apache POI 库中触发，项目自身无相关实现，忽略 -->
    <issue id="TrustAllX509TrustManager" severity="ignore" />

    <!-- 核心 API 兼容性：保持 error 级别 -->
    <issue id="NewApi" severity="error" />
    <issue id="InlinedApi" severity="error" />
    <issue id="PermissionImpliesUnsupportedChromeOsHardware" severity="error" />
</lint>
