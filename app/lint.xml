<?xml version="1.0" encoding="UTF-8" ?>
<lint xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    checkTestSources="true" >

    <!--
        历史遗留翻译问题：项目支持 4 个非默认语言（de/ja/ko/zh），但大量英文
        字符串尚未翻译。手工补齐 250+ 条翻译条目成本高且易出错，因此先把
        MissingTranslation / ExtraTranslation 从 error 降级为 warning，让
        lint 聚焦在真正会阻断构建的代码/布局问题。后续可按语言分批补齐翻译。
    -->
    <issue id="MissingTranslation" severity="warning" />
    <issue id="ExtraTranslation" severity="warning" />

    <!-- 依赖库原生库或系统限制，项目层面无法直接修复，先忽略 -->
    <issue id="Aligned16KB" severity="ignore" />
    <issue id="LockedOrientationActivity" severity="ignore" />
    <issue id="AppBundleLocaleChanges" severity="ignore" />
    <issue id="QueryPermissionsNeeded" severity="ignore" />
    <issue id="SelectedPhotoAccess" severity="ignore" />
    <issue id="MonochromeLauncherIcon" severity="ignore" />
    <issue id="PermissionImpliesUnsupportedChromeOsHardware" severity="error" />
</lint>
